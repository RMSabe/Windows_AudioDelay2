<local:MyPage
	x:Class="AudioDelay.ChooseAudioDevicePage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:AudioDelay"
	mc:Ignorable="d">

	<Grid>
		<TextBlock
			Name="TextBlock1"
			HorizontalAlignment="Center"
			VerticalAlignment="Top"
			Margin="20px"
			FontSize="35px"
			TextAlignment="Center"
			Text="Select Audio Device"/>

		<ListBox
			Name="ListBox1"
			HorizontalAlignment="Center"
			VerticalAlignment="Top"
			Width="600px"
			Height="60px"
			Margin="100px"
			SelectionMode="Single"/>

		<Button
			Name="Button1"
			HorizontalAlignment="Center"
			VerticalAlignment="Bottom"
			Width="200px"
			Height="20px"
			Margin="120px"
			Content="Cancel"
			Click="onButton1Clicked"/>

		<Button
			Name="Button2"
			HorizontalAlignment="Center"
			VerticalAlignment="Bottom"
			Width="200px"
			Height="20px"
			Margin="90px"
			Content="Choose Selected Device"
			Click="onButton2Clicked"/>

		<Button
			Name="Button3"
			HorizontalAlignment="Center"
			VerticalAlignment="Bottom"
			Width="200px"
			Height="20px"
			Margin="60px"
			Content="Choose Default Device"
			Click="onButton3Clicked"/>
	</Grid>
</local:MyPage>
